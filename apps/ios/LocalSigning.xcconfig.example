// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

JARVIS_CODE_SIGN_STYLE = Automatic
JARVIS_DEVELOPMENT_TEAM = YOUR_TEAM_ID

JARVIS_APP_BUNDLE_ID = ai.jarvis.client
JARVIS_SHARE_BUNDLE_ID = ai.jarvis.client.share
JARVIS_ACTIVITY_WIDGET_BUNDLE_ID = ai.jarvis.client.activitywidget
JARVIS_WATCH_APP_BUNDLE_ID = ai.jarvis.client.watchkitapp
JARVIS_WATCH_EXTENSION_BUNDLE_ID = ai.jarvis.client.watchkitapp.extension

// Leave empty with automatic signing.
JARVIS_APP_PROFILE =
JARVIS_SHARE_PROFILE =
